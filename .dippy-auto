# .dippy-auto — LLM layer rules
# Evaluated BEFORE calling the LLM. If matched, LLM is skipped.
# Format: <action> <type> <pattern>
# Actions: allow, deny, ask
# Types: path (script file path), cmd (command pattern)
# Patterns: glob-style (* matches anything)

# --- Project scripts ---
allow-path scripts/*
allow-path tests/*
allow-path test_*

# --- Deploy / infra ---
ask-path deploy/*
ask-path infra/*
ask-path k8s/*

# --- System paths ---
deny-path /etc/*
deny-path /usr/*
deny-path /var/*

# --- Safe command patterns ---
allow-cmd uv run python -c "print*
allow-cmd python3 -c "print*
allow-cmd curl localhost*
allow-cmd curl 127.0.0.1*
allow-cmd curl 0.0.0.0*
allow-cmd curl http://localhost*
allow-cmd curl http://127.0.0.1*
allow-cmd curl http://0.0.0.0*
allow-cmd curl -s localhost*
allow-cmd curl -s http://localhost*
allow-cmd curl -s 127.0.0.1*
allow-cmd curl -s http://127.0.0.1*

# --- Dangerous command patterns ---
deny-cmd *rm -rf /*
deny-cmd *sudo *
deny-cmd *chmod 777*
deny-cmd *> /dev/sd*
deny-cmd *mkfs*
deny-cmd *dd if=*

# --- Uncertain ---
ask-cmd *curl *
ask-cmd *wget *
